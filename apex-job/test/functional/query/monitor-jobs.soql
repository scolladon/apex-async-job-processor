SELECT Count(Id), 
       Status__c, JobDescription__r.ProcessorName__c, 
       MAX(JobDescription__r.MaxChunkSize__c) MaxBulk, 
       MAX(JobDescription__r.SmallestFailingChunk__c) SmallestFailingChunk, 
       MAX(JobDescription__r.SuccessStreak__c) SuccessStreak,
       MAX(JobDescription__r.ConsecutiveFailures__c) ConsecutiveFailure,
       MAX(JobDescription__r.ConsecutiveVariationCount__c) ConsecutiveVariationCount,
       MAX(JobDescription__r.LearningRate__c) LearningRate,
       MAX(JobDescription__r.VariationResetCount__c) VariationResetCount,
       MAX(JobDescription__r.KillCooldownCount__c) KillCooldownCount,
       SUM(AttemptNumber__c) NbTry,
       MAX(JobDescription__r.CpuTimeBaseConsumption__c) BaseCpuTime, 
       MAX(JobDescription__r.CpuTimePerItemConsumption__c) PerItemCpuTime, 
       MAX(JobDescription__r.CpuTimeSafety__c) SafetyCpuTime, 
       FORMAT(MIN(NextExecutionDateTime__c)) NextExecutionDateTime, 
       FORMAT(MIN(LastModifiedDate)) LastExecutionDateTime
FROM JobRequest__c 
GROUP BY Status__c, JobDescription__r.ProcessorName__c 
ORDER BY Status__c, JobDescription__r.ProcessorName__c